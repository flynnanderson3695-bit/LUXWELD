# Copy to .env and edit. Auto-loaded by the npm scripts (--env-file-if-exists).

# 'production' enables HTTPS-only cookies + trust proxy. Use in deployment.
NODE_ENV=development

PORT=3000

# Public HTTPS origin used to build QR links (and the app wrapper target).
# In production set this to your real domain, e.g. https://warranty.luxweld.com
# Locally, set to your phone-reachable LAN address, e.g. http://192.168.1.50:3000
BASE_URL=

# Secret used to sign the session cookie. MUST be a long random string in prod.
SESSION_SECRET=change-me-to-a-long-random-string

# SQLite database file path. DATABASE_URL is accepted as an alias.
# Point this at a persistent volume in production so records survive deploys.
DB_PATH=./data/app.db

# Directory for uploaded photos. Must be a persistent volume in production.
# UPLOAD_DIR is preferred; UPLOAD_ROOT is also accepted.
UPLOAD_DIR=./data/uploads

# --- Admin bootstrap (first run only) ---
# The admin recovery account (email + password) is seeded ONCE when the DB is
# empty. In production ADMIN_PASSWORD is REQUIRED (no default is ever seeded);
# in development it defaults to admin123. Manage everyone else in Admin → Users.
ADMIN_EMAIL=admin@luxweld.com.au
ADMIN_PASSWORD=change-me-strong

# --- Role allowlists (comma-separated emails, optional) ---
# Emails here are auto-assigned this role on first Google/Apple sign-in. Roles
# are still stored in the DB and overridable by an admin; everyone else who
# signs in starts as `installer`.
ADMIN_EMAILS=
PRODUCTION_EMAILS=

# --- Google OAuth (Sign in with Google) ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (Web). Authorised redirect URI must be BASE_URL/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; derived from BASE_URL if omitted:
# GOOGLE_CALLBACK_URL=https://warranty.luxweld.com.au/auth/google/callback

# --- Apple OAuth (Sign in with Apple) — optional ---
# Leave blank to hide the Apple button. Requires an Apple Developer account:
# a Services ID, your Team ID, a Key ID, and the .p8 private key contents.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the .p8 contents with literal \n for newlines, or a file path.
APPLE_PRIVATE_KEY=
# APPLE_CALLBACK_URL=https://warranty.luxweld.com.au/auth/apple/callback

# --- Cloud archive / backup (Cloudflare R2 or any S3-compatible bucket) ---
# When set, every warranty is mirrored to the bucket as a self-describing folder
# (info.json + record.txt + the photos), plus DB snapshots under backups/.
# Leave blank to run on the Railway volume only (the app still works; the
# Archive page shows "Cloud backup OFF").
# Cloudflare R2: create a bucket + an API token (Object Read & Write).
R2_ENDPOINT=            # https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=              # e.g. luxweld-warranties
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# For real AWS S3 instead: leave R2_ENDPOINT blank and set S3_REGION + S3_BUCKET
# + S3_ACCESS_KEY_ID + S3_SECRET_ACCESS_KEY.
# CLOUD_PREFIX=warranties

# --- Mobile app wrapper (build-time only; NOT used by the web server) ---
# The HTTPS URL the Android/iOS shell loads. Set it, then run:
#   LUXWELD_APP_URL=https://warranty.luxweld.com.au npm run set-app-url
# (Usually the same value as BASE_URL.) See mobile/README.md.
# LUXWELD_APP_URL=https://warranty.luxweld.com.au
