<%- include('partials/head', { title: 'Users' }) %>
<%
  const errs = { invalid: 'Provide a name, email and a password of at least 6 characters.', exists: 'A user with that email already exists.' };
  const e = error && errs[error];
%>
<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-semibold text-zinc-100 mb-1">Users &amp; roles</h1>
  <p class="text-sm text-zinc-500 mb-4">Roles are controlled here, not by the sign-in provider. New Google/Apple sign-ins arrive as <span class="text-zinc-300">installer</span> (or <span class="text-zinc-300">pending</span>); promote to production/admin as needed.</p>

  <% if (saved) { %><div class="mb-3 text-sm bg-emerald-500/10 text-emerald-300 ring-1 ring-emerald-500/30 rounded-lg px-3 py-2">Saved.</div><% } %>
  <% if (e) { %><div class="mb-3 text-sm bg-red-500/10 text-red-300 ring-1 ring-red-500/30 rounded-lg px-3 py-2"><%= e %></div><% } %>

  <div class="card !p-0 overflow-x-auto mb-6">
    <table class="w-full text-sm">
      <thead class="text-zinc-500 text-left border-b border-ink-600">
        <tr>
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium">Email</th>
          <th class="px-4 py-3 font-medium">Sign-in</th>
          <th class="px-4 py-3 font-medium">Role</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-700">
        <% users.forEach(u => { %>
          <tr class="hover:bg-ink-700/40 align-middle">
            <td class="px-4 py-3 text-zinc-100"><%= u.name %></td>
            <td class="px-4 py-3 text-zinc-300"><%= u.email || (u.username ? u.username : '—') %></td>
            <td class="px-4 py-3"><span class="badge bg-ink-700 text-zinc-300 ring-1 ring-ink-600 capitalize"><%= u.provider %></span></td>
            <td class="px-4 py-3">
              <form method="post" action="/admin/users/<%= u.id %>/role" class="flex gap-1 items-center">
                <select name="role" class="input !py-1.5 !px-2 text-xs w-32">
                  <% roles.forEach(r => { %><option value="<%= r %>" <%= u.role===r?'selected':'' %>><%= r %></option><% }) %>
                </select>
                <button class="btn-ghost !py-1.5 !px-2 text-xs">Set</button>
              </form>
            </td>
            <td class="px-4 py-3 text-zinc-400"><%= u.active ? 'Active' : 'Disabled' %></td>
            <td class="px-4 py-3 text-right">
              <div class="flex gap-2 justify-end items-center">
                <form method="post" action="/admin/users/<%= u.id %>/password" class="flex gap-1"
                      onsubmit="return confirm('Set a new password for <%= u.email || u.name %>?');">
                  <input name="password" type="text" placeholder="new password" class="input !py-1.5 !px-2 w-28 text-xs" />
                  <button class="btn-ghost !py-1.5 !px-2 text-xs">Reset</button>
                </form>
                <form method="post" action="/admin/users/<%= u.id %>/toggle">
                  <button class="btn-ghost !py-1.5 !px-2 text-xs"><%= u.active ? 'Disable' : 'Enable' %></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 class="font-semibold text-zinc-200 mb-3">Add account (email + password)</h2>
    <p class="text-sm text-zinc-500 mb-3">For staff without Google, or admin recovery. Most production users should sign in with Google once you add an allowlist or promote them here.</p>
    <form method="post" action="/admin/users" class="grid sm:grid-cols-2 gap-3">
      <label class="text-sm text-zinc-400">Name<input name="name" required class="input mt-1" /></label>
      <label class="text-sm text-zinc-400">Email<input name="email" type="email" required class="input mt-1" /></label>
      <label class="text-sm text-zinc-400">Role
        <select name="role" class="input mt-1">
          <option value="production">production</option>
          <option value="admin">admin</option>
          <option value="genius">genius</option>
          <option value="installer">installer</option>
          <option value="pending">pending</option>
        </select>
      </label>
      <label class="text-sm text-zinc-400">Password (min 6)<input name="password" type="text" required minlength="6" class="input mt-1" /></label>
      <div class="sm:col-span-2"><button class="btn-gold !py-2.5">Create account</button></div>
    </form>
  </div>
</div>
<%- include('partials/foot') %>
