<%- include('partials/head', { title: 'Users' }) %>
<%
  const errs = { invalid: 'Please provide a name, username and a password of at least 4 characters.', exists: 'That username already exists.' };
  const e = error && errs[error];
%>
<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-semibold text-zinc-100 mb-1">Staff users</h1>
  <p class="text-sm text-zinc-500 mb-4">Admins and production team members. Production users only see production screens.</p>

  <% if (saved) { %><div class="mb-3 text-sm bg-emerald-500/10 text-emerald-300 ring-1 ring-emerald-500/30 rounded-lg px-3 py-2">Saved.</div><% } %>
  <% if (e) { %><div class="mb-3 text-sm bg-red-500/10 text-red-300 ring-1 ring-red-500/30 rounded-lg px-3 py-2"><%= e %></div><% } %>

  <div class="card !p-0 overflow-x-auto mb-6">
    <table class="w-full text-sm">
      <thead class="text-zinc-500 text-left border-b border-ink-600">
        <tr><th class="px-4 py-3 font-medium">Name</th><th class="px-4 py-3 font-medium">Username</th><th class="px-4 py-3 font-medium">Role</th><th class="px-4 py-3 font-medium">Status</th><th class="px-4 py-3"></th></tr>
      </thead>
      <tbody class="divide-y divide-ink-700">
        <% users.forEach(u => { %>
          <tr class="hover:bg-ink-700/40">
            <td class="px-4 py-3 text-zinc-100"><%= u.name %></td>
            <td class="px-4 py-3 font-mono text-zinc-300"><%= u.username %></td>
            <td class="px-4 py-3"><span class="badge bg-gold-500/15 text-gold-300 ring-1 ring-gold-500/30 capitalize"><%= u.role %></span></td>
            <td class="px-4 py-3 text-zinc-400"><%= u.active ? 'Active' : 'Disabled' %></td>
            <td class="px-4 py-3 text-right">
              <div class="flex gap-2 justify-end items-center">
                <form method="post" action="/admin/users/<%= u.id %>/password" class="flex gap-1"
                      onsubmit="return confirm('Reset password for <%= u.username %>?');">
                  <input name="password" type="text" placeholder="new password" class="input !py-1.5 !px-2 w-32 text-xs" />
                  <button class="btn-ghost !py-1.5 !px-2 text-xs">Reset</button>
                </form>
                <form method="post" action="/admin/users/<%= u.id %>/toggle">
                  <button class="btn-ghost !py-1.5 !px-2 text-xs"><%= u.active ? 'Disable' : 'Enable' %></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 class="font-semibold text-zinc-200 mb-3">Add user</h2>
    <form method="post" action="/admin/users" class="grid sm:grid-cols-2 gap-3">
      <label class="text-sm text-zinc-400">Name<input name="name" required class="input mt-1" /></label>
      <label class="text-sm text-zinc-400">Username<input name="username" required autocapitalize="none" class="input mt-1" /></label>
      <label class="text-sm text-zinc-400">Email<input name="email" type="email" class="input mt-1" /></label>
      <label class="text-sm text-zinc-400">Role
        <select name="role" class="input mt-1">
          <option value="production">Production</option>
          <option value="admin">Admin</option>
        </select>
      </label>
      <label class="text-sm text-zinc-400 sm:col-span-2">Password<input name="password" type="text" required minlength="4" class="input mt-1" /></label>
      <div class="sm:col-span-2"><button class="btn-gold !py-2.5">Create user</button></div>
    </form>
  </div>
</div>
<%- include('partials/foot') %>
