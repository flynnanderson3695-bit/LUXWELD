<%- include('partials/head', { title: 'Sign in' }) %>
<div class="max-w-sm mx-auto mt-6 sm:mt-10">
  <div class="text-center mb-6">
    <% if (typeof hasLogo !== 'undefined' && hasLogo) { %>
      <img src="/luxweld-velux-trusted.svg" alt="LUXWELD" class="h-12 mx-auto mb-3" />
    <% } else { %>
      <div class="inline-grid place-items-center w-14 h-14 rounded-2xl bg-gradient-to-b from-gold-400 to-gold-600 text-ink-900 text-2xl font-black mx-auto mb-3">L</div>
      <h1 class="tracking-[0.3em] text-gold-300 font-semibold">LUXWELD</h1>
    <% } %>
    <p class="text-sm text-zinc-500 mt-1">Warranty &amp; insurance registration</p>
  </div>

  <div class="card">
    <h2 class="text-lg font-semibold text-zinc-100 mb-1">Staff sign in</h2>
    <p class="text-sm text-zinc-500 mb-4">Installers don't sign in — just scan the product QR code.</p>

    <% if (error) { %>
      <div class="mb-4 text-sm bg-red-500/10 text-red-300 ring-1 ring-red-500/30 rounded-lg px-3 py-2"><%= error %></div>
    <% } %>

    <!-- OAuth providers (shown only when configured) -->
    <% if (googleEnabled) { %>
      <a href="/auth/google<%= next ? '?next=' + encodeURIComponent(next) : '' %>"
         class="btn-ghost w-full mb-2 !justify-center">
        <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.4 29.3 35 24 35c-6.1 0-11-4.9-11-11s4.9-11 11-11c2.8 0 5.4 1.1 7.3 2.8l5.7-5.7C33.5 6.5 28.9 4.5 24 4.5 13.2 4.5 4.5 13.2 4.5 24S13.2 43.5 24 43.5 43.5 34.8 43.5 24c0-1.2-.1-2.3-.4-3.5z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 13 24 13c2.8 0 5.4 1.1 7.3 2.8l5.7-5.7C33.5 6.5 28.9 4.5 24 4.5 16.3 4.5 9.7 8.8 6.3 14.7z"/><path fill="#4CAF50" d="M24 43.5c5.2 0 9.8-2 13.3-5.2l-6.1-5.2C29.2 34.6 26.7 35.5 24 35.5c-5.3 0-9.7-2.6-11.3-7l-6.5 5C9.6 39.2 16.2 43.5 24 43.5z"/><path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.2-2.2 4.1-4.1 5.4l6.1 5.2C40.9 35.6 43.5 30.3 43.5 24c0-1.2-.1-2.3-.4-3.5z"/></svg>
        Continue with Google
      </a>
    <% } %>
    <% if (appleEnabled) { %>
      <a href="/auth/apple<%= next ? '?next=' + encodeURIComponent(next) : '' %>"
         class="btn-ghost w-full mb-2 !justify-center"> Continue with Apple</a>
    <% } %>

    <% if (googleEnabled || appleEnabled) { %>
      <div class="flex items-center gap-3 my-4 text-xs text-zinc-600">
        <span class="h-px bg-ink-600 flex-1"></span> or email <span class="h-px bg-ink-600 flex-1"></span>
      </div>
    <% } %>

    <!-- Email / password (admin recovery + admin-created accounts) -->
    <form method="post" action="/login" class="space-y-4">
      <input type="hidden" name="next" value="<%= next %>" />
      <div>
        <label class="label">Email</label>
        <input name="email" type="email" value="<%= email %>" autofocus required autocomplete="username" class="input" />
      </div>
      <div>
        <label class="label">Password</label>
        <input type="password" name="password" required autocomplete="current-password" class="input" />
      </div>
      <button class="btn-gold w-full">Sign in</button>
    </form>
  </div>
</div>
<%- include('partials/foot') %>
